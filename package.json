{
  "name": "@penpage/agent",
  "version": "0.1.0",
  "description": "AI coding pad - rich UI for Claude Code, Gemini CLI & Codex CLI",
  "type": "module",
  "bin": {
    "penpage-agent": "./dist/bin/cli.js"
  },
  "scripts": {
    "dev": "tsx src/bin/cli.ts",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "vite build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "penpage",
    "agent",
    "ai",
    "coding",
    "cli",
    "claude-code",
    "gemini-cli",
    "codex-cli",
    "ai-coding",
    "prompt",
    "developer-tools"
  ],
  "author": "penpage",
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/middie": "^9.3.2",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "open": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
